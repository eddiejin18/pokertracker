{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/free-poker-tracker-app",
      "dest": "/build/index.html"
    },
    {
      "src": "/free-poker-tracker-download",
      "dest": "/build/index.html"
    },
    {
      "src": "/best-free-poker-tracker",
      "dest": "/build/index.html"
    },
    {
      "src": "/poker-tracker-4",
      "dest": "/build/index.html"
    },
    {
      "src": "/poker-tracker-4-free",
      "dest": "/build/index.html"
    },
    {
      "src": "/poker-tracker-app",
      "dest": "/build/index.html"
    },
    {
      "src": "/poker-bankroll-tracker",
      "dest": "/build/index.html"
    },
    {
      "src": "/online-poker-tracker",
      "dest": "/build/index.html"
    },
    {
      "src": "/poker-tracker-download",
      "dest": "/build/index.html"
    },
    {
      "src": "/poker-tracker-pt4",
      "dest": "/build/index.html"
    },
    {
      "src": "/poker-tracker-free",
      "dest": "/build/index.html"
    },
    {
      "src": "/guides/track-poker-sessions-profit",
      "dest": "/build/guides/track-poker-sessions-profit.html"
    },
    {
      "src": "/guides/poker-bankroll-management",
      "dest": "/build/guides/poker-bankroll-management.html"
    },
    {
      "src": "/guides/poker-hourly-rate",
      "dest": "/build/guides/poker-hourly-rate.html"
    },
    {
      "src": "/guides/spreadsheet-vs-poker-tracker",
      "dest": "/build/guides/spreadsheet-vs-poker-tracker.html"
    },
    {
      "src": "/guides/online-vs-live-poker-tracking",
      "dest": "/build/guides/online-vs-live-poker-tracking.html"
    },
    {
      "src": "/guides/poker-tournament-tracking",
      "dest": "/build/guides/poker-tournament-tracking.html"
    },
    {
      "src": "/(.*)",
      "dest": "/build/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
