# Copy to .env and fill in values for local development.

# Required: Postgres connection string (e.g. local Docker, Neon, Supabase)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/pokertracker

# Optional: API port (default 5001 — avoids macOS using port 5000 for AirPlay)
# PORT=5001

# Optional in dev; required in production
# JWT_SECRET=your-long-random-secret

# Optional: override API URL for the React app (leave unset to use /api in browser, proxied to :5001 in dev)
# REACT_APP_API_URL=http://127.0.0.1:5001/api

# Optional: where CRA dev proxy forwards /api (default http://127.0.0.1:5001)
# PROXY_API_TARGET=http://127.0.0.1:5001
